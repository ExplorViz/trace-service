@namespace("net.explorviz.persistence.avro")
protocol SpanDataProtocol {
  record SpanData {
    string spanId;
    string parentId;
    string traceId;
    string landscapeTokenId;
    long startTime;
    long endTime;
    string applicationName;
    string filePath;
    string functionName;
    string language;
    union { null, string } className = null;
    union { null, string } commitHash = null;
  }
}
